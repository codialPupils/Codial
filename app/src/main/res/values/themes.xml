<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Codial" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/yellow</item>
        <item name="colorPrimaryVariant">@color/splash_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/yellow</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/yellow</item>
        <!-- Customize your theme here. -->
    </style>

    <declare-styleable name="MaskedEditText">
        <attr name="mask" format="string" />
        <attr name="allowed_chars" format="string" />
        <attr name="enable_ime_action" format="boolean" />
        <attr name="denied_chars" format="string" />
        <attr name="char_representation" format="string" />
        <attr name="keep_hint" format="boolean" />
    </declare-styleable>

    <style name="FragmentStyle">
        <item name="android:background">@color/white</item>
    </style>

    <style name="SplashBackground">
        <item name="android:background">@color/yellow</item>
    </style>

    <style name="BottomSheetDialogStyle">
        <item name="android:background">#CFCECE</item>
    </style>

    <style name="LogoImage">
        <item name="android:src">@drawable/codial_logo</item>
    </style>

    <style name="ActionBarStyle">
        <item name="android:background">@color/yellow</item>
    </style>

    <style name="TextColor">
        <item name="android:textColor">@color/text_color_light</item>
    </style>

    <style name="TintColor">
        <item name="android:tint">@color/tint_color_light</item>
    </style>

    <style name="TextInputLayoutStyle">
        <item name="boxStrokeColor">@color/splash_color</item>
    </style>

    <style name="CardSViewtyle">
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <style name="ImageViewBackground">
        <item name="android:background">@drawable/default_image_light</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="BoxesStyle">
        <item name="android:textColor">@color/text_color_light</item>
        <item name="otp_box_background">@drawable/bg_otp_box_light</item>
        <item name="otp_box_background_active">@drawable/bg_otp_box_active_light</item>
        <item name="otp_box_background_inactive">@drawable/bg_otp_box_inactive_light</item>
        <item name="otp_box_background_error">@drawable/bg_otp_box_error_light</item>
        <item name="otp_box_background_success">@drawable/bg_otp_box_success_light</item>
    </style>

    <style name="ChekNumberDialogStyle">
        <item name="android:background">@drawable/check_number_dialog_style_light</item>
    </style>

    <style name="MaterialButtonStyle">
        <item name="android:textColor">@color/text_color_light</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>