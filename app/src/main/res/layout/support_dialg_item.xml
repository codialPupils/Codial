<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="@dimen/_10sdp"
    android:paddingBottom="@dimen/_20sdp"
    android:layout_height="wrap_content">

    <TextView
        android:gravity="center_horizontal"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:id="@+id/support_text"
        android:text="@string/biz_bilan_qanday_bog_lanish_mumkin"
        android:textStyle="normal"
        android:textColor="@color/black"
        android:textSize="@dimen/_13sdp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <ImageView
        android:id="@+id/support_on_telegram"
        android:src="@drawable/ic_telegram"
        app:layout_constraintTop_toBottomOf="@id/support_text"
        app:layout_constraintLeft_toLeftOf="@id/support_text"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:layout_marginTop="@dimen/_6sdp"
        android:layout_marginStart="@dimen/_10sdp"
        app:layout_constraintTop_toBottomOf="@id/support_text"
        app:layout_constraintLeft_toRightOf="@id/support_on_telegram"
        app:layout_constraintRight_toRightOf="@id/support_text"
        app:layout_constraintBottom_toBottomOf="@id/support_on_telegram"
        android:id="@+id/support_text_on_telegram"
        android:text="@string/t_me_codial_uz"
        android:textSize="@dimen/_11sdp"
        android:textColor="@color/black"
        android:textStyle="bold|normal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"/>

    <ImageView
        app:layout_constraintTop_toBottomOf="@id/support_on_telegram"
        app:layout_constraintLeft_toLeftOf="@id/support_on_telegram"
        android:src="@drawable/ic_instagram"
        android:layout_marginTop="@dimen/_10sdp"
        android:id="@+id/support_on_instagram"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        app:layout_constraintTop_toBottomOf="@id/support_text_on_telegram"
        app:layout_constraintLeft_toRightOf="@id/support_on_telegram"
        app:layout_constraintRight_toRightOf="@id/support_text_on_telegram"
        android:layout_marginStart="@dimen/_10sdp"
        android:textColor="@color/black"
        android:textStyle="bold|normal"
        android:textSize="@dimen/_11sdp"
        android:layout_marginTop="@dimen/_12sdp"
        android:text="@string/codial_link"
        android:id="@+id/support_text_on_instagram"
        android:layout_width="0dp"
        android:layout_height="wrap_content"/>

    <ImageView
        android:id="@+id/support_on_you_tube"
        app:layout_constraintTop_toBottomOf="@id/support_on_instagram"
        app:layout_constraintLeft_toLeftOf="@id/support_on_instagram"
        android:src="@drawable/ic_youtube"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/support_text_on_you_tube"
        android:text="You Tube Channel"
        app:layout_constraintTop_toBottomOf="@id/support_text_on_instagram"
        app:layout_constraintLeft_toRightOf="@id/support_on_you_tube"
        app:layout_constraintRight_toRightOf="@id/support_text_on_instagram"
        android:textSize="@dimen/_11sdp"
        android:textStyle="bold|normal"
        android:textColor="@color/black"
        android:layout_marginTop="@dimen/_12sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"/>



</androidx.constraintlayout.widget.ConstraintLayout>